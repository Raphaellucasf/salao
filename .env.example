# Supabase Configuration
# Obtenha suas credenciais em: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_publica_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# n8n Webhook Configuration (Opcional)
N8N_WEBHOOK_URL=url_do_webhook_n8n_aqui

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Instruções de Setup:
# 1. Copie este arquivo como .env.local: cp .env.example .env.local
# 2. Preencha com suas credenciais reais do Supabase
# 3. Nunca faça commit do arquivo .env.local no Git
#
# Onde encontrar cada chave no painel Supabase:
#   NEXT_PUBLIC_SUPABASE_URL        → Settings > API > Project URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY   → Settings > API > anon (public)
#   SUPABASE_SERVICE_ROLE_KEY       → Settings > API > service_role (secret)
#
# IMPORTANTE: SUPABASE_SERVICE_ROLE_KEY é usada apenas em API Routes (server-side).
# Nunca prefixe com NEXT_PUBLIC_ — ela não pode ser exposta no browser.
