# ============================================================
# TEMPLATE DE CONFIGURAÇÃO — DOIS AMBIENTES SUPABASE
# ============================================================
#
# SETUP:
#   - Desenvolvimento (npm run dev)  → .env.local          (gitignored)
#   - Produção (build / Vercel)      → .env.production.local ou Vercel Dashboard
#
# COPIE os blocos abaixo para os arquivos corretos:
# ============================================================

# --- BLOCO: .env.local (Supabase de TESTE — só localhost) ---
# NEXT_PUBLIC_SUPABASE_URL=https://blzargagmyjdihdkmcwg.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua_anon_key_de_teste>
# SUPABASE_SERVICE_ROLE_KEY=<sua_service_role_key_de_teste>

# --- BLOCO: .env.production.local / Vercel (Supabase do CLIENTE) ---
NEXT_PUBLIC_SUPABASE_URL=https://woshbfbqgfxkenzylfub.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_publica_do_cliente_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_do_cliente_aqui

# n8n Webhook Configuration (Opcional)
N8N_WEBHOOK_URL=url_do_webhook_n8n_aqui

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Onde encontrar cada chave no painel Supabase:
#   NEXT_PUBLIC_SUPABASE_URL        → Settings > API > Project URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY   → Settings > API > anon (public)
#   SUPABASE_SERVICE_ROLE_KEY       → Settings > API > service_role (secret)
#
# IMPORTANTE: SUPABASE_SERVICE_ROLE_KEY é usada apenas em API Routes (server-side).
# Nunca prefixe com NEXT_PUBLIC_ — ela não pode ser exposta no browser.
#
# Ordem de carregamento Next.js:
#   .env.local              → todos os ambientes (dev e prod)
#   .env.development.local  → só npm run dev
#   .env.production.local   → só npm run build / next start
# ============================================================
